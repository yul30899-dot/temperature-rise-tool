{
  "name": "temp_rise_tool",
  "private": true,
  "version": "1.0.0",
  "description": "温升数据整理工具",
  "author": "User",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "oxlint",
    "preview": "vite preview",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on tcp:8888 && cross-env NODE_ENV=development electron .\"",
    "electron:build": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.temprise.app",
    "productName": "温升数据分析工具",
    "directories": {
      "output": "release"
    },
    "win": {
      "icon": "build/icon.png",
      "verifyUpdateCodeSignature": false,
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ]
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "jimp": "^0.16.13",
    "oxlint": "^1.71.0",
    "png-to-ico": "^3.0.1",
    "vite": "^8.1.1",
    "wait-on": "^9.0.10",
    "@tailwindcss/vite": "^4.3.2",
    "clsx": "^2.1.1",
    "exceljs": "^4.4.0",
    "file-saver": "^2.0.5",
    "idb-keyval": "^6.2.6",
    "lucide-react": "^1.23.0",
    "papaparse": "^5.5.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "recharts": "^3.9.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "xlsx-populate": "^1.21.0"
  }
}